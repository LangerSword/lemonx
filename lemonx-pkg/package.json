{
  "name": "lemonx",
  "version": "0.2.0",
  "description": "Generate CircleCI config for AI-powered test generation, execution, and self-healing fixes",
  "type": "module",
  "bin": {
    "lemonx": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/cli/index.ts --bundle --platform=node --outdir=dist/cli --format=esm --external:dotenv",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "dotenv": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "latest",
    "typescript": "latest"
  }
}
